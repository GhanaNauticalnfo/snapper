{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "args": ["node-env=production"]
      },
      "configurations": {
        "development": {
          "args": ["node-env=development"]
        }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "api:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "api:build:development"
        },
        "production": {
          "buildTarget": "api:build:production"
        }
      }
    },
    "typeorm": {
      "executor": "nx:run-commands",
      "options": {
        "command": "typeorm-ts-node-commonjs"
      }
    },
    "migration:generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx run api:typeorm -- migration:generate apps/api/src/migrations/InitialSchema -d apps/api/src/config/typeorm.config.ts"
      },
      "configurations": {
        "custom": {
          "command": "nx run api:typeorm -- migration:generate apps/api/src/migrations/{args.name} -d apps/api/src/config/typeorm.config.ts"
        }
      }
    },
    "migration:create": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx run api:typeorm -- migration:create apps/api/src/migrations/EmptyMigration"
      },
      "configurations": {
        "custom": {
          "command": "nx run api:typeorm -- migration:create apps/api/src/migrations/{args.name}"
        }
      }
    },
    "migration:run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx run api:typeorm -- migration:run -d apps/api/src/config/typeorm.config.ts"
      }
    },
    "migration:revert": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx run api:typeorm -- migration:revert -d apps/api/src/config/typeorm.config.ts"
      }
    }
  },
  "tags": []
}