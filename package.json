{
  "name": "@snapper/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start:dev": "nest start --watch",
    "db:up": "docker compose -f docker/local/docker-compose.yml up -d",
    "db:down": "docker compose -f docker/local/docker-compose.yml down",
    "db:logs": "docker compose -f docker/local/docker-compose.yml logs -f",
    "db:restart": "npm run db:down && npm run db:up",
    "typeorm:api:direct": "ts-node -r tsconfig-paths/register -P apps/api/tsconfig.app.json ./node_modules/typeorm/cli.js --dataSource apps/api/src/config/typeorm.config.ts",
    "migration:generate": "npm run typeorm:api:direct -- migration:generate",
    "migration:run": "npm run typeorm:api:direct -- migration:run",
    "migration:revert": "npm run typeorm:api:direct -- migration:revert",
    "typeorm": "npm run typeorm:api:direct --"
  },
  "private": true,
